# Font Configuration
font-size = 12

# Window Configuration
window-decoration = false
window-padding-x = 12
window-padding-y = 12
background-opacity = 1.0
background-blur-radius = 32

# Cursor Configuration
cursor-style = block
cursor-style-blink = true

# Scrollback
scrollback-limit = 3023

# Terminal features
mouse-hide-while-typing = true
copy-on-select = false
confirm-close-surface = false

# Disable annoying copied to clipboard
app-notifications = no-clipboard-copy,no-config-reload




# Material 3 UI elements
unfocused-split-opacity = 0.7
unfocused-split-fill = #44464f

# Tab configuration
gtk-titlebar = false

# Shell integration
shell-integration = detect
shell-integration-features = cursor,sudo,title,no-cursor
keybind = shift+enter=text:\n

# Rando stuff
gtk-single-instance = true

# Dank color generation
theme = metal-archspire


#key bindings
# 使用 Ctrl+a 作为 leader key

# Pane 分割
keybind = ctrl+a>\=new_split:right
keybind = ctrl+a>-=new_split:down

# # Tab 操作
keybind = ctrl+a>c=new_tab
keybind = ctrl+a>n=next_tab
keybind = ctrl+a>p=previous_tab
keybind = ctrl+a>&=close_tab

# --- 移动焦点 (仅 Ctrl+a + h/j/k/l) ---
keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>j=goto_split:down
keybind = ctrl+a>k=goto_split:up
keybind = ctrl+a>l=goto_split:right
# 调整大小 (Ctrl+a + Alt + h/j/k/l)
keybind = ctrl+a>alt+h=resize_split:left,50
keybind = ctrl+a>alt+j=resize_split:down,50
keybind = ctrl+a>alt+k=resize_split:up,50
keybind = ctrl+a>alt+l=resize_split:right,50
